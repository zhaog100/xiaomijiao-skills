# =================================
# Bounty Hunter Agent Configuration
# =================================

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://bounty_hunter:bounty_hunter@localhost:5432/bounty_hunter

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# GitHub
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
GITHUB_USERNAME=your-github-username

# AI Provider for bounty analysis (pick one)
# Options: anthropic | openai | openrouter
ANALYST_AI_PROVIDER=anthropic

# Model to use — leave blank to use the provider default
# anthropic default : claude-sonnet-4-20250514
# openai default    : gpt-4o-mini
# openrouter default: openrouter/auto  (picks best available model automatically)
# Other openrouter examples: anthropic/claude-3-5-sonnet, openai/gpt-4o, google/gemini-pro
ANALYST_AI_MODEL=

# API Keys (only the one matching ANALYST_AI_PROVIDER is required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# Bounty Platforms (optional)
ALGORA_API_KEY=
GITCOIN_API_KEY=
ISSUEHUNT_API_KEY=

# n8n (optional workflow engine)
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=

# Scout Settings
SCOUT_SCAN_INTERVAL_HOURS=6
SCOUT_MIN_BOUNTY_USD=50
SCOUT_MAX_BOUNTY_AGE_DAYS=90

# Analyst Settings
ANALYST_MIN_ROI_SCORE=40
ANALYST_MAX_DIFFICULTY=hard

# Solver Settings
SOLVER_MAX_CONCURRENT=5
SOLVER_TIMEOUT_MULTIPLIER=2
SOLVER_MAX_ITERATIONS=3
SOLVER_CODING_AGENT=claude  # claude | codex | openai

# Submitter Settings
SUBMITTER_HUMAN_REVIEW_FIRST_N=20
SUBMITTER_RATE_LIMIT_PER_HOUR=3

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
