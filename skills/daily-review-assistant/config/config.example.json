{
  "version": "1.0.0",
  "workspace": "auto",
  "paths": {
    "memoryDir": "memory",
    "knowledgeDir": "knowledge",
    "logsDir": "logs",
    "memoryFile": "MEMORY.md",
    "heartbeatFile": "HEARTBEAT.md",
    "knowledgeIndex": "KNOWLEDGE-INDEX.md"
  },
  "reviewTimes": {
    "morning": "0 12 * * *",
    "full": "50 23 * * *"
  },
  "git": {
    "remoteBranch": "master",
    "autoCommit": true,
    "autoPush": true,
    "commitMessagePrefix": "chore(daily)"
  },
  "features": {
    "taskReview": true,
    "gitReview": true,
    "issueReview": true,
    "learningReview": true,
    "gapAnalysis": true,
    "memoryUpdate": true,
    "knowledgeUpdate": true
  },
  "thresholds": {
    "memoryStaleHours": 24,
    "heartbeatStaleHours": 12
  }
}
