{
  "name": "daily-review-assistant",
  "version": "1.2.2",
  "description": "定时回顾更新助手。定时（中午 12 点、晚上 23:50）自动回顾今日工作，查漏补缺，更新记忆和知识库。",
  "author": "思捷娅科技 (SJYKJ)",
  "license": "MIT",
  "copyright": "© 2026 思捷娅科技 (SJYKJ). All rights reserved.",
  "keywords": [
    "daily-review",
    "memory-update",
    "gap-analysis",
    "automatic",
    "openclaw",
    "context-management",
    "knowledge-base",
    "git"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zhaog100/openclaw-skills"
  },
  "bugs": {
    "url": "https://github.com/zhaog100/openclaw-skills/issues"
  },
  "homepage": "https://clawhub.com/skills/daily-review-assistant",
  "engines": {
    "openclaw": ">=1.0.0"
  },
  "scripts": {
    "install": "bash scripts/install.sh",
    "start": "bash skill.sh review",
    "test": "bash skill.sh status"
  },
  "config": {
    "reviewTimes": ["12:00", "23:50"],
    "workspace": "/home/zhaog/.openclaw/workspace",
    "features": {
      "taskReview": true,
      "gitReview": true,
      "issueReview": true,
      "learningReview": true,
      "gapAnalysis": true,
      "memoryUpdate": true,
      "knowledgeUpdate": true,
      "gitAutoCommit": true
    }
  }
}
