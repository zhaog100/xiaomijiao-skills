# aiemon - AI Efficiency Monitor CLI
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ERROR_HANDLER="${SCRIPT_DIR}/../utils/error-handler.sh"
[ -f "$ERROR_HANDLER" ] && source "$ERROR_HANDLER" 2>/dev/null || true

DATA_DIR="${SCRIPT_DIR}/data"
export DATA_DIR
mkdir -p "$DATA_DIR"

usage() {
  cat <<'EOF'
aiemon - AI Efficiency Monitor v1.0.0

Usage: aiemon <command> [options]

Commands:
  collect    收集 AI 执行数据
  analyze    分析浪费模式
  report     生成效率报告
  cost       计算模型成本
  trends     分析效率趋势
  patterns   管理浪费模式

Options:
  --source <src>    数据源 (openclaw)
  --days <n>        天数范围
  --format <fmt>    报告格式 (markdown|json)
  --model <name>    模型名称
  --tokens <n>      Token 数量
  --patterns <list> 模式列表 (all|名称)

Examples:
  aiemon collect --source openclaw --days 7
  aiemon analyze --patterns all
  aiemon report --format markdown --days 7
  aiemon cost --model glm-5-turbo --tokens 10000
  aiemon trends --days 30
  aiemon patterns list
EOF
}

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
  collect)
    source "${SCRIPT_DIR}/src/collector.sh"
    aiemon_collect "$@"
    ;;
  analyze)
    source "${SCRIPT_DIR}/src/analyzer.sh"
    aiemon_analyze "$@"
    ;;
  report)
    source "${SCRIPT_DIR}/src/reporter.sh"
    aiemon_report "$@"
    ;;
  cost)
    source "${SCRIPT_DIR}/src/cost_calc.sh"
    aiemon_cost "$@"
    ;;
  trends)
    source "${SCRIPT_DIR}/src/reporter.sh"
    aiemon_trends "$@"
    ;;
  patterns)
    source "${SCRIPT_DIR}/src/patterns_list.sh"
    aiemon_patterns "$@"
    ;;
  *)
    usage
    ;;
esac
