{
  "name": "knowledge-graph-builder",
  "version": "1.0.0",
  "description": "知识图谱构建工具 - 从文档中自动提取知识和关系",
  "author": "思捷娅科技 (SJYKJ)",
  "license": "MIT",
  "main": "skill.sh",
  "scripts": {
    "build": "./skill.sh build",
