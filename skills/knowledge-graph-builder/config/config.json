{
  "storage": {
    "type": "sqlite",
    "path": "./data/knowledge_graph.db",
    "neo4j": {
      "uri": "bolt://localhost:7687",
      "user": "neo4j",
      "password": "password"
    }
  },
  "extractor": {
    "languages": ["zh", "en"],
    "ai_engine": "ollama",
    "ollama": {
      "model": "llama3",
      "base_url": "http://localhost:11434"
    }
  },
  "relation": {
    "min_confidence": 0.5,
    "templates": {
      "is-a": ["是一种", "属于", "是"],
      "part-of": ["是...的一部分", "包含", "组成"],
      "related-to": ["相关", "关联", "联系"],
      "causes": ["导致", "引起", "造成"],
      "before": ["在...之前", "先于"],
      "after": ["在...之后", "后于"]
    }
  },
  "web": {
    "host": "0.0.0.0",
    "port": 8765,
    "debug": false
  },
  "log": {
    "level": "INFO",
    "file": "./logs/kg-builder.log"
  }
}
