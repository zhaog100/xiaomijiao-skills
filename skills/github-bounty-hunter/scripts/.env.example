# GitHub Bounty Hunter 配置文件
# 复制此文件为 .env 并填入真实值

# GitHub Token（必需）
# 创建方式：https://github.com/settings/tokens
# 权限要求：repo, read:user, user:email
GITHUB_TOKEN=your_github_token_here

# Algora API Key（可选）
# 获取方式：https://algora.io/settings/api
ALGORA_API_KEY=your_algora_api_key_here

# 收款地址（必需）⚠️ 请修改成您自己的地址！
# USDT TRC20 地址
# 
# 获取方式：
# 1. OKX: 资产 → 充币 → USDT → TRC20 网络 → 复制地址
# 2. 币安：钱包 → 现货 → USDT → 充值 → TRC20 → 复制地址
# 3. TronLink: 打开钱包 → 点击 USDT → 收款 → 复制地址
#
# ⚠️ 重要：当前是示例地址，千万不要使用！
# 如果不修改，钱会打到别人的钱包！
PAYMENT_ADDRESS=您的_USDT_TRC20_地址_请修改

# 通知配置（可选）
# 飞书 Webhook URL
FEISHU_WEBHOOK=
