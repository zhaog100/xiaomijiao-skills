# GitHub Bounty Hunter 配置文件
# 复制此文件为 .env 并填入真实值

# GitHub Token（必需）
# 创建方式：https://github.com/settings/tokens
# 权限要求：repo, read:user, user:email
GITHUB_TOKEN=your_github_token_here

# Algora API Key（可选）
# 获取方式：https://algora.io/settings/api
ALGORA_API_KEY=your_algora_api_key_here

# 收款地址（必需）
# USDT TRC20 地址
PAYMENT_ADDRESS=TGu4W5T6q4KvLAbmXmZSRpUBNRCxr2aFTP

# 通知配置（可选）
# 飞书 Webhook URL
FEISHU_WEBHOOK=
