tests/
practice/
scripts/
tools/
skills/
qmd/
projects/

# 临时HTML查看器
*.html

# 临时Shell脚本
*.sh
*.ps1
!install.sh

# 临时JS脚本
*.js
!screenshot-dashboard.js

# 临时音频文件
*.mp3
*.wav
*.silk

