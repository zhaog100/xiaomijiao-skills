# Git忽略文件配置（优化版）

# 依赖目录
node_modules/
package-lock.json
bun.lock

# 临时文件
*.log
*.tmp
*.temp
puppeteer-test.png
moltbook-check.png
*.png
*.jpg
*.jpeg
*.gif
*.mp3
*.wav
*.silk
*.b64

# 环境变量和配置
.env
.env.local
.env.*.local
*.json
!.gitignore
!package.json

# 系统文件
.DS_Store
Thumbs.db

# IDE配置
.vscode/
.idea/
*.swp
*.swo

# 构建输出
dist/
build/
.cache/

# 测试文件
test-*.js
test-*.sh
test-*.mjs
*-test.js
*-test.sh

# 临时脚本
*.test.js
*.test.sh
verify-*.js
check-*.js
scrape-*.js
screenshot-*.js

# 调试文件
qmd-*.log
*-debug.log
*.log.*
*-debug-*.md

# 临时文档
TEST-*.md
CURRENT-*.md
TEMP-*.md
*-TEMP.md
*-PLAN.md
*-REPORT.md
*-COMPLETE.md
*-REMINDER.md
*-FAILURE.md
*-TODO.md
*-CHECK-*.md
*-GUIDE.md
!DAILY-REVIEW-GUIDE.md
!OPTIMIZE-PLAN.md

# 备份文件
*.backup
*.bak
*~

# 知识库（独立维护）
knowledge-base/

# 平台配置（包含敏感信息）
.clawhub/
.clawtasks/
.moltbook/
.openclaw/
backups/
config/

# 输出和临时目录
output/
screenshots/
diagrams/
