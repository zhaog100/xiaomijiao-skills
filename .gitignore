# Git 忽略文件配置（合并版）

# 依赖目录
node_modules/
package-lock.json
bun.lock

# 临时文件
.vector-search-status.md
Z:/

# 记忆文件（已备份到 MEMORY.md）
memory/*.md
!memory/README.md
memory/*.json

# 历史报告文档
*报告.md
*REPORT*.md
*COMPLETE*.md
*PLAN*.md
*GUIDE.md
*STATUS*.md
*CHECK*.md
*CONFIGURED.md
*SETUP.md
*SUMMARY.md
*TODO*.md

# 保留核心文档
!AGENTS.md
!SOUL.md
!USER.md
!IDENTITY.md
!BOOT.md
!HEARTBEAT.md
!CRON-CONFIG.md
!DOCS-INDEX.md
!MEMORY.md
!TOOLS.md

# 平台配置（包含敏感信息）
.clawhub/
.clawtasks/
.moltbook/
.openclaw/

# 会话处理文件
.session-processed/

# 日志文件（自动生成的）
skills/*/logs/*.log
skills/*/data/*.json

# 但保留技能核心文件
!skills/*/package.json
!skills/*/SKILL.md
!skills/*/README.md
!skills/*/install.sh
!skills/**/*.py
!skills/**/*.js
!skills/**/*.sh
!skills/**/config/**
!skills/**/scripts/**
!skills/**/core/**
!skills/**/modes/**

# 图片文件（由 Git LFS 管理）
# *.png, *.jpg, *.jpeg 已通过 .gitattributes 由 LFS 追踪
*.gif
*.mp3
*.wav
*.silk

# 测试文件
puppeteer-test.png
moltbook-check.png

# 忽略日志文件
logs/*.log
logs/*/
*.log

# 忽略临时文件
*.tmp
*.bak
*.swp
*~

# 忽略青龙面板文件
qinglong/

# 忽略缓存
__pycache__/
*.pyc
*.pyo
.node_modules/
venv/

# 忽略临时测试文件
test-*.sh
*-test.sh
