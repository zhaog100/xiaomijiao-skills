node_modules/
package-lock.json
bun.lock
__pycache__/
*.pyc
*.pyo
.node_modules/
venv/

# ===== 临时文件 =====
*.tmp
*.bak
*.swp
*~
.vector-search-status.md

# ===== 敏感配置 =====
.clawhub/
.clawtasks/
.moltbook/
.openclaw/
.env
.env.local

# ===== 日志和数据 =====
logs/*.log
skills/*/logs/*.log
skills/*/data/*.json
*.log

# ===== 记忆文件（已备份到 MEMORY.md）=====
memory/*.md
!memory/README.md
memory/*.json

